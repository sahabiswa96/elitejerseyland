// elite-jersey-land/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  ORDERED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
}

enum DiscountType {
  FIXED
  PERCENT
}

model User {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String   @unique
  phone        String?  @unique
  address      String?
  passwordHash String
  role         UserRole @default(CUSTOMER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cart   Cart?
  orders CustomerOrder[]

  @@map("users")
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  category         String
  subcategory      String?
  team             String?
  brand            String?
  quality          String?
  price            Float
  oldPrice         Float?
  sizes            String
  shortDescription String?
  fullDescription  String?  @db.Text
  mainImage        String
  galleryImages    String
  stock            Int      @default(0)
  isPublished      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("products")
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

model CustomerOrder {
  id                String        @id @default(cuid())
  orderNumber       String        @unique
  userId            String?
  customerName      String
  phone             String
  email             String
  address           String
  total             Float
  promoCode         String?
  discount          Float         @default(0)
  paymentStatus     PaymentStatus @default(UNPAID)
  status            OrderStatus   @default(ORDERED)
  utr               String?       // <-- নতুন যোগ হয়েছে
  paymentScreenshot String?       // <-- নতুন যোগ হয়েছে
  createdAt         DateTime      @default(now())

  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String?
  name      String
  image     String
  price     Float
  quantity  Int
  subtotal  Float
  createdAt DateTime @default(now())

  order   CustomerOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  houseName String?
  roadName  String?
  address   String?
  pincode   String?
  message   String?
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model Setting {
  id           String   @id @default(cuid())
  storeName    String?
  supportEmail String?
  supportPhone String?
  address      String?
  logo         String?
  currency     String?  @default("INR")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("settings")
}

model Promo {
  id             String       @id @default(cuid())
  code           String       @unique
  discountType   DiscountType
  discountValue  Float
  minOrderAmount Float?
  isActive       Boolean      @default(true)
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("promos")
}

model Banner {
  id        String   @id @default(cuid())
  imageUrl  String
  createdAt DateTime @default(now())

  @@map("banners")
}